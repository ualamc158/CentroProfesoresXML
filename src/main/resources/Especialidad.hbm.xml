<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN" "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="model">
    <class name="Especialidad" table="ESPECIALIDAD">
        <id name="idEspecialidad" column="ESPECIALIDAD" type="string">
            <generator class="assigned"/>
        </id>
        <property name="nombreEspe" column="NOMBRE_ESPE" type="string"/>

        <set name="profesores" inverse="true">
            <key column="ESPECIALIDAD"/>
            <one-to-many class="Profesor"/>
        </set>
    </class>
</hibernate-mapping>